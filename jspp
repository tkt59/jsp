-- Exemple bouton stylé
local function StyledBtn(parent, text, callback)
    local b = Instance.new("TextButton", parent)
    b.Size = UDim2.new(1, 0, 0, 40)
    b.BackgroundColor3 = C.Surface
    b.Text = text
    b.TextColor3 = C.Text
    b.Font = Enum.Font.GothamBold
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(callback)
end

StyledBtn(P_Player, "Vitesse (50)", function() LocalPlayer.Character.Humanoid.WalkSpeed = 50 end)
StyledBtn(P_Player, "Noclip", function() State.Noclip = not State.Noclip end)

local P_Troll = CreateTab("Troll")
