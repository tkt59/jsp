-- ===================== ANIMATION D'OUVERTURE =====================
local function ToggleUI()
    if Main.Visible then
        -- Animation Fermeture
        TweenService:Create(Blur, TweenInfo.new(0.3), {Size = 0}):Play()
        Main:TweenSizeAndPosition(UDim2.new(0, 0, 0, 0), UDim2.new(0.5, 0, 0.5, 0), "In", "Back", 0.3, true, function()
            Main.Visible = false
            Blur.Enabled = false
        end)
    else
        -- Animation Ouverture
        Main.Visible = true
        Main.Size = UDim2.new(0, 0, 0, 0)
        Main.Position = UDim2.new(0.5, 0, 0.5, 0)
        Blur.Enabled = true
        TweenService:Create(Blur, TweenInfo.new(0.5), {Size = 15}):Play()
        Main:TweenSizeAndPosition(UDim2.new(0, 420, 0, 520), UDim2.new(0.5, -210, 0.5, -260), "Out", "Elastic", 0.7, true)
    end
end

