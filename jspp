-- ===================== ZIZI PANEL V3.0 GHOST =====================
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- Fix pour ton exécuteur (Strings au lieu d'Enums pour la console)
local ALIGN_CENTER = "Center"

-- ===================== INTERFACE TRANSPARENTE =====================
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "ZiziPanel_Ghost"
ScreenGui.Parent = (gethui and gethui()) or game:GetService("CoreGui")

local Main = Instance.new("Frame")
Main.Size = UDim2.new(0, 400, 0, 500)
Main.Position = UDim2.new(0.5, -200, 0.5, -250)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Main.BackgroundTransparency = 0.4 -- EFFET GHOST
Main.BorderSizePixel = 0
Main.Parent = ScreenGui
Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 12)

-- Bordure RGB
local UIStroke = Instance.new("UIStroke", Main)
UIStroke.Thickness = 2
UIStroke.ApplyStrokeMode = "Border"
task.spawn(function()
    while true do
        UIStroke.Color = Color3.fromHSV(tick() % 5 / 5, 0.7, 1)
        task.wait()
    end
end)

-- Prénom du Panel
local Title = Instance.new("TextLabel", Main)
Title.Text = "ZIZI PANEL"
Title.Size = UDim2.new(1, 0, 0, 50)
Title.BackgroundTransparency = 1
Title.TextColor3 = Color3.new(1, 1, 1)
