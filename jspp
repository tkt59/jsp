-- ===================== ANIMATION D'OUVERTURE =====================
local function TogglePanel()
    if Main.Visible then
        -- Fermeture
        Blur.Enabled = false
        Main:TweenSizeAndPosition(UDim2.new(0, 0, 0, 0), UDim2.new(0.5, 0, 0.5, 0), "Out", "Quad", 0.3, true, function()
            Main.Visible = false
        end)
    else
        -- Ouverture
        Main.Visible = true
        Main.Size = UDim2.new(0, 0, 0, 0)
        Main.Position = UDim2.new(0.5, 0, 0.5, 0)
        Blur.Enabled = true
        TweenService:Create(Blur, TweenInfo.new(0.4), {Size = 15}):Play()
        Main:TweenSizeAndPosition(UDim2.new(0, 420, 0, 520), UDim2.new(0.5, -210, 0.5, -260), "Out", "Elastic", 0.6, true)
    end
end

