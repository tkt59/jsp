-- Fin de l'UI (Exemple simplifié pour test)
local TabNames = {"Player", "Game", "Troll", "ESP", "Other", "Credits"}
local TabPages = {}
for _, name in ipairs(TabNames) do
    local p = Instance.new("ScrollingFrame")
    p.Size = UDim2.new(1, 0, 1, 0)
    p.BackgroundTransparency = 1
    p.Visible = (name == "Player")
    p.Parent = ContentArea
    TabPages[name] = p
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 400/#TabNames, 1, 0)
    btn.Text = name
    btn.TextColor3 = C.Text
    btn.BackgroundTransparency = 1
    btn.Parent = TabBar
    btn.MouseButton1Click:Connect(function()
        for _, page in pairs(TabPages) do page.Visible = false end
        p.Visible = true
    end)
end

