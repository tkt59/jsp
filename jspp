-- ===================== FONCTIONS & BOUTONS = --

local function AddButton(name, func)
    local btn = Instance.new("TextButton", Container)
    btn.Text = name
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.BackgroundTransparency = 0.2
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = "GothamMedium"
    btn.TextSize = 14
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(func)
end

-- Fly & Noclip States
local flying = false
local noclip = false

AddButton("FLY (V)", function()
    flying = not flying
    print("Fly: " .. tostring(flying))
end)

AddButton("ESP PLAYERS", function()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local h = p.Character:FindFirstChild("Highlight") or Instance.new("Highlight", p.Character)
            h.FillColor = Color3.new(1, 0, 0)
        end
    end
end)

AddButton("TP TO RANDOM PLAYER", function()
    local plrs = Players:GetPlayers()
    local randomPlayer = plrs[math.random(1, #plrs)]
    if randomPlayer and randomPlayer.Character then
        LocalPlayer.Character:MoveTo(randomPlayer.Character.HumanoidRootPart.Position)
    end
end)

AddButton("SPECTATE", function()
    local target = Players:GetPlayers()[math.random(1, #Players:GetPlayers())]
    workspace.CurrentCamera.CameraSubject = target.Character.Humanoid
end)

AddButton("NOCLIP", function()
    noclip = not noclip
end)

AddButton("TOUTES LES ANIMATIONS", function()
    -- Charge une animation de danse au hasard
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://3333499508" 
    LocalPlayer.Character.Humanoid:LoadAnimation(anim):Play()
end)

-- ===================== BOUCLES (FLY/NOCLIP) = --
RunService.Stepped:Connect(function()
    if noclip then
        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)

-- Drag & Toggle (Touche P)
local dragging, dragStart, startPos
Main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true dragStart = input.Position startPos = Main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

UserInputService.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Enum.KeyCode.P then Main.Visible = not Main.Visible end
end)
